#include<iostream>
using namespace std;
int main() {
	int n{}, digit{}, reverse = 0, length = 0;
	cout << "Enter a number: ";
	cin >> n;
	int original = n;
	while (n != 0) {
		digit = n % 10;
		reverse = reverse * 10 + digit;
		length++;
		n /= 10;
	}
	if (original == reverse) {
		cout << "Palindrome";
	}
	else {
		cout << "Non Palindrome";
	}
	//cout << "The reverse number: " << reverse << endl;
	return 0;
};
